{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "opener:default",
    "fs:default",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/**/*" },
        { "path": "$MUSIC/**/*" },
        { "path": "$AUDIO/**/*" },
        { "path": "$DOWNLOAD/**/*" },
        { "path": "$DESKTOP/**/*" }
      ]
    }
  ]
}
